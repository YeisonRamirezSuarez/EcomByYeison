# =============================================================================
#  ECOM BY YEISON — Variables de entorno
#  Copia este archivo como .env.local y rellena cada valor
#  cp .env.example .env.local
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# 1. SANITY (CMS — gratis)   https://sanity.io
# ─────────────────────────────────────────────────────────────────────────────
#
# PASO 1 → Ve a https://sanity.io/manage y crea una cuenta
# PASO 2 → Clic en "Create new project" → ponle un nombre (ej: ecom-by-yeison)
# PASO 3 → Copia el "Project ID" que aparece en la pantalla
#           → pégalo en NEXT_PUBLIC_SANITY_PROJECT_ID
# PASO 4 → El dataset por defecto es "production" → déjalo así
# PASO 5 → Ve a tu proyecto → pestaña "API" → sección "Tokens"
# PASO 6 → Clic "Add API token":
#           • Nombre: "editor-token" | Permisos: EDITOR → copia → SANITY_API_TOKEN
#           • Nombre: "read-token"   | Permisos: VIEWER → copia → SANITY_API_READ_TOKEN

NEXT_PUBLIC_SANITY_PROJECT_ID=          # ej: k9s08w2p
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-03-20
SANITY_API_TOKEN=                       # empieza con sk...
SANITY_API_READ_TOKEN=                  # empieza con sk...


# ─────────────────────────────────────────────────────────────────────────────
# 2. CLERK (Autenticación — gratis)   https://clerk.com
# ─────────────────────────────────────────────────────────────────────────────
#
# PASO 1 → Ve a https://clerk.com → crea una cuenta
# PASO 2 → Clic "Create application" → elige nombre y métodos de login
#           (activa Email + Google como mínimo)
# PASO 3 → En el dashboard ve a la sección "API Keys" (menú lateral izquierdo)
# PASO 4 → Copia "Publishable Key"  → NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
#           Copia "Secret Key"       → CLERK_SECRET_KEY

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=      # empieza con pk_test_...
CLERK_SECRET_KEY=                       # empieza con sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up


# ─────────────────────────────────────────────────────────────────────────────
# 3. STRIPE (Pagos — gratis en modo test)   https://stripe.com
# ─────────────────────────────────────────────────────────────────────────────
#
# PASO 1 → Ve a https://stripe.com → crea una cuenta
# PASO 2 → En el dashboard ve a "Developers" → "API keys"
# PASO 3 → Copia "Secret key"  → STRIPE_SECRET_KEY  (empieza con sk_test_...)
#
# WEBHOOK (necesario para confirmar pagos):
# PASO 4 → En "Developers" → "Webhooks" → "Add endpoint"
# PASO 5 → URL del endpoint:
#           • Local:      usa https://dashboard.stripe.com/test/webhooks/create?endpoint_location=local
#                         e instala Stripe CLI: stripe listen --forward-to localhost:3000/api/webhook
#           • Producción: https://tu-dominio.com/api/webhook
# PASO 6 → Selecciona el evento: checkout.session.completed
# PASO 7 → Copia el "Signing secret" (whsec_...)  → STRIPE_WEBHOOK_SECRET

STRIPE_SECRET_KEY=                      # empieza con sk_test_...
STRIPE_WEBHOOK_SECRET=                  # empieza con whsec_...


# ─────────────────────────────────────────────────────────────────────────────
# 4. APP
# ─────────────────────────────────────────────────────────────────────────────
#
# En local siempre es http://localhost:3000
# En producción ponlo con tu dominio real: https://ecom-by-yeison.vercel.app

NEXT_PUBLIC_BASE_URL=http://localhost:3000
